{
  "name": "auraforge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tauri": "npm run tauri -- dev",
    "dev:lean": "./scripts/lean-dev.sh",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "release:tauri": "npm run tauri -- build",
    "release:tauri:debug": "npm run tauri -- build --debug",
    "clean:heavy": "./scripts/cleanup-heavy.sh",
    "clean:all-local": "./scripts/cleanup-all-local.sh",
    "prepare": "husky",
    "commitlint": "commitlint",
    "test": "npm run test:web && npm run test:rust",
    "test:web": "vitest run",
    "test:web:watch": "vitest",
    "test:smoke": "vitest run src/test/smoke/workflow.smoke.test.ts",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "git:guard:branch": "bash scripts/git/guard-branch.sh",
    "git:guard:no-main-push": "bash scripts/git/guard-no-main-push.sh",
    "git:guard:atomic": "bash scripts/git/guard-atomic.sh",
    "git:guard:generated": "bash scripts/git/guard-generated.sh",
    "git:guard:large-files": "bash scripts/git/guard-large-files.sh",
    "git:guard:secrets": "bash scripts/git/guard-secrets.sh",
    "git:guard:all": "npm run git:guard:branch && npm run git:guard:atomic && npm run git:guard:generated && npm run git:guard:large-files && npm run git:guard:secrets",
    "git:commit:propose": "node scripts/git/propose-commit-message.mjs",
    "git:session:save": "bash scripts/git/session-save.sh",
    "git:session:resume": "bash scripts/git/session-resume.sh",
    "pr:notes": "bash scripts/git/generate-pr-notes.sh",
    "perf:bundle": "node scripts/perf/bundle-report.mjs",
    "perf:build": "node scripts/perf/measure-build-time.mjs",
    "perf:assets": "bash scripts/perf/check-assets.sh",
    "perf:memory": "node --expose-gc scripts/perf/memory-smoke.mjs",
    "perf:lhci": "npx --yes @lhci/cli@0.15.1 autorun --config=lighthouserc.json",
    "perf:lhci:prod": "npx --yes @lhci/cli@0.15.1 autorun --config=.lighthouserc.production.json",
    "perf:summary": "node scripts/perf/summarize.mjs",
    "phase4:prereqs": "bash scripts/release/check-phase4-prereqs.sh saagar210/auraforge",
    "phase4:gates": "bash scripts/release/run-phase4-gates.sh saagar210/auraforge",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "clsx": "^2.1.0",
    "lucide-react": "^0.400.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  }
}
